{
  "name": "lasts-scriber",
  "version": "1.0.0",
  "description": "Song scribing / lyric timestamping tool",
  "main": "src/main.js",
  "type": "commonjs",
  "author": "last",
  "license": "ISC",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "build": {
    "appId": "com.last.scriber",
    "productName": "last's scriber",

    "directories": {
      "output": "dist"
    },

    "files": [
      "src/**/*",
      "assets/**/*",
      "index.html",
      "preload.js"
    ],

    "win": {
      "target": "nsis",
      "icon": "./assets/favicon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1"
  }
}